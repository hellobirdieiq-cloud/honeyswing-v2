{
  "expo": {
    "name": "honeyswing",
    "slug": "honeyswing-v2",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "honeyswingv2",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#111111"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 23
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "ios": {
      "infoPlist": {
        "NSCameraUsageDescription": "HoneySwing uses the camera to record and analyze your golf swing.",
        "NSLocationWhenInUseUsageDescription": "HoneySwing does not use your location. This message may appear because of underlying system components."
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.honeyswing.honeyswing-v2",
      "buildNumber": "6"
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.honeyswing.honeyswingv2"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6d20482e-c974-426d-83d9-13ff4e5c8c99"
      }
    },
    "owner": "honeyswing"
  }
}