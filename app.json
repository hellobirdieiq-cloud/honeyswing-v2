{
  "expo": {
    "name": "honeyswing",
    "slug": "honeyswing-v2",
    "version": "1.10.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "honeyswingv2",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#111111"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0",
            "extraPods": [
              {
                "name": "MediaPipeTasksVision",
                "version": "~> 0.10.9"
              }
            ]
          },
          "android": {
            "minSdkVersion": 23
          }
        }
      ],
      "expo-video",
      "./plugins/withHoneyNative",
      "@clerk/expo",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "ios": {
      "associatedDomains": [
        "applinks:honeyswing.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "HoneySwing uses the camera to record and analyze your golf swing.",
        "NSLocationWhenInUseUsageDescription": "HoneySwing does not use your location. This message may appear because of underlying system components.",
        "NSMotionUsageDescription": "Allow $(PRODUCT_NAME) to access your device motion",
        "CADisableMinimumFrameDurationOnPhone": true,
        "ITSAppUsesNonExemptEncryption": false
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.honeyswing.honeyswing-v2",
      "buildNumber": "49",
      "appleTeamId": "B3774Z5A69"
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.honeyswing.honeyswingv2"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6d20482e-c974-426d-83d9-13ff4e5c8c99"
      }
    },
    "owner": "honeyswing",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/6d20482e-c974-426d-83d9-13ff4e5c8c99"
    }
  }
}
