require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']
  
  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['RCT_NEW_ARCH_ENABLED'] ||= '0' if podfile_properties['newArchEnabled'] == 'false'
ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

prepare_react_native_project!

target 'honeyswing' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    # Clerk: Resolve SPM packages synchronously during pod install
    # This ensures packages are downloaded before the user opens Xcode
    # We wait until the end of post_install to ensure workspace is fully written
    at_exit do
      workspace_path = File.join(__dir__, 'honeyswing.xcworkspace')
      if File.exist?(workspace_path)
        puts ""
        puts "📦 [Clerk] Resolving Swift Package dependencies..."
        puts "   This may take a minute on first run..."
        # Use backticks to capture output and check exit status
        output = `xcodebuild -resolvePackageDependencies -workspace "#{workspace_path}" -scheme "honeyswing" 2>&1`
        if $?.success?
          puts "✅ [Clerk] Swift Package dependencies resolved successfully"
        else
          puts "⚠️  [Clerk] SPM resolution output:"
          puts output.lines.last(10).join
        end
        puts ""
      end
    end

    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    mediapipe_libs = %w[MediaPipeTasksCommon MediaPipeTasksVision]
    mediapipe_search_paths = mediapipe_libs.map { |n| %Q("$(PODS_XCFRAMEWORKS_BUILD_DIR)/#{n}") }.join(' ')
    installer.pods_project.targets.each do |t|
      next unless t.name == 'Pods-honeyswing'
      t.build_configurations.each do |config|
        next unless config.base_configuration_reference
        xcconfig_path = config.base_configuration_reference.real_path
        text = File.read(xcconfig_path)

        # 1. -l → -framework (existing behavior).
        # CocoaPods emits -lMediaPipeTasksCommon (static-lib syntax) but the pod ships
        # an .xcframework, so the linker needs -framework.
        mediapipe_libs.each do |name|
          text = text.gsub(%Q(-l"#{name}"), %Q(-framework "#{name}"))
        end

        # 2. Append extracted-slice search paths if missing.
        # CocoaPods writes "${PODS_ROOT}/<pod>/frameworks" (the .xcframework wrapper),
        # but `-framework` needs the extracted .framework under PODS_XCFRAMEWORKS_BUILD_DIR.
        needs_append = mediapipe_libs.any? { |n| !text.include?(%Q("$(PODS_XCFRAMEWORKS_BUILD_DIR)/#{n}")) }
        if needs_append
          pre_append_text = text
          text = text.sub(
            /^(FRAMEWORK_SEARCH_PATHS = \$\(inherited\))/,
            "\\1 #{mediapipe_search_paths}"
          )
          # Fail loud if the line shape changed and the sub didn't actually inject.
          # Without this, a future CocoaPods that re-shapes the FRAMEWORK_SEARCH_PATHS line
          # would silently skip the append while the -l→-framework rewrite still succeeds,
          # reproducing the exact "ld: framework 'MediaPipeTasksCommon' not found" failure
          # this hook exists to prevent.
          if text == pre_append_text
            raise "[honeyswing post_install] Failed to append MediaPipe extracted-slice paths to " \
                  "FRAMEWORK_SEARCH_PATHS in #{xcconfig_path}. Inspect the FRAMEWORK_SEARCH_PATHS " \
                  "line — its shape may have changed in a CocoaPods upgrade. Expected it to start " \
                  "with: FRAMEWORK_SEARCH_PATHS = $(inherited)"
          end
        end

        File.write(xcconfig_path, text)
      end
    end
  end
end
